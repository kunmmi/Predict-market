# =============================================================================
# Environment configuration — copy to .env.local and fill in your values.
# =============================================================================
# See docs/deployment-regions.md for full regional deployment guidance.
# =============================================================================


# -----------------------------------------------------------------------------
# REGION
# -----------------------------------------------------------------------------
# Controls which region-specific providers and feature flags are active.
# Values: global (default) | cn
# Leave unset or set to 'global' for the standard deployment.
APP_REGION=global


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# Create a project at https://supabase.com
# Keys are in: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — required for admin operations (optional for MVP development)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
# Public URL of this deployment. Used for auth redirects and canonical links.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Initial admin account email (used for seeding / role checks if needed)
# ADMIN_EMAIL=admin@example.com


# -----------------------------------------------------------------------------
# ROUTING & CDN
# -----------------------------------------------------------------------------
# Leave both empty to use relative paths from the app origin.

# Override the base URL for API calls (e.g. when frontend/API are on separate domains)
# NEXT_PUBLIC_API_BASE_URL=

# Override the base URL for user-facing assets (images, uploads, fonts).
# For CN: point to a domestic CDN (Alibaba Cloud CDN, Tencent CDN, etc.)
# NEXT_PUBLIC_ASSET_BASE_URL=


# -----------------------------------------------------------------------------
# ANALYTICS  (currently disabled — set analyticsEnabled: true in regions.ts first)
# -----------------------------------------------------------------------------
# Valid values by region:
#   global: posthog | mixpanel | none
#   cn:     baidu | umeng | none
# NOTE: Google Analytics is blocked in CN — do not use it.

NEXT_PUBLIC_ANALYTICS_PROVIDER=none
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-write-key


# -----------------------------------------------------------------------------
# PAYMENT  (Phase 9+ — not yet integrated)
# -----------------------------------------------------------------------------
# Valid values by region:
#   global: stripe | none
#   cn:     alipay | wechatpay | none
# NOTE: Stripe is not available to end-users in Mainland China — do not use for CN.

NEXT_PUBLIC_PAYMENT_PROVIDER=none
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# CN future:
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# WECHATPAY_APP_ID=
# WECHATPAY_MCH_ID=
# WECHATPAY_API_KEY=


# -----------------------------------------------------------------------------
# EMAIL  (not yet integrated — Supabase handles auth emails)
# -----------------------------------------------------------------------------
# Valid values by region:
#   global: resend | sendgrid | nodemailer | none
#   cn:     alimail | nodemailer | none
# NOTE: SendGrid and Mailgun have delivery issues in CN — prefer alimail for CN.

EMAIL_PROVIDER=resend
# Without a verified domain, use: onboarding@resend.dev (delivers to your Resend account email only)
# With a verified domain, use:   noreply@yourdomain.com
DEFAULT_FROM_EMAIL=onboarding@resend.dev

# Resend (current provider) — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Future / alternative providers:
# GMAIL_USER=your-gmail@gmail.com
# GMAIL_APP_PASSWORD=your-app-password-here
# SENDGRID_API_KEY=SG....
# CN providers:
# ALIMAIL_ACCESS_KEY_ID=
# ALIMAIL_ACCESS_KEY_SECRET=
# ALIMAIL_ACCOUNT_NAME=


# -----------------------------------------------------------------------------
# STORAGE / CDN  (not yet integrated)
# -----------------------------------------------------------------------------
# Valid values by region:
#   global: vercel-blob | s3 | r2 | none
#   cn:     oss | cos | none
# NOTE: AWS S3 / Cloudflare R2 are accessible from CN but may be slow.
#       For CN users, prefer Alibaba Cloud OSS or Tencent COS.

STORAGE_PROVIDER=none
# Global providers:
# BLOB_READ_WRITE_TOKEN=vercel_blob_...        # Vercel Blob
# AWS_ACCESS_KEY_ID=                           # S3
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
# CLOUDFLARE_R2_ACCOUNT_ID=                   # R2
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=
# CN providers:
# ALIYUN_OSS_REGION=                          # Alibaba Cloud OSS
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# TENCENT_COS_REGION=                         # Tencent Cloud COS
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_BUCKET=
