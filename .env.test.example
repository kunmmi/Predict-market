# Test environment variables for Playwright E2E tests
# Copy this to .env.test and fill in your values

# The URL to test against — defaults to localhost:3000
# TEST_BASE_URL=https://predict-market-xi.vercel.app

# Admin account credentials (must already exist in the database)
TEST_ADMIN_EMAIL=your-admin@email.com
TEST_ADMIN_PASSWORD=your-admin-password

# Optional: pre-existing test user (for faster tests that skip signup)
# TEST_USER_EMAIL=testuser@example.com
# TEST_USER_PASSWORD=testpassword
